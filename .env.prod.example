# Production Environment Configuration
# Copy this file to .env and update values as needed

# ============ API Configuration ============
ENV=production
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./app/data/bibliotheque.db

# Security - MUST change in production!
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============ NGINX Configuration ============
NGINX_WORKER_PROCESSES=auto
NGINX_KEEPALIVE_TIMEOUT=65
NGINX_CLIENT_MAX_BODY_SIZE=20M

# ============ Database Backup ============
# Keep backups for 7 days
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_MINUTES=60

# ============ Redis Configuration ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============ Monitoring & Uptime ============
UPTIME_KUMA_ADMIN_USERNAME=admin
UPTIME_KUMA_ADMIN_PASSWORD=changepassword123

# Monitoring URLs (configure in Uptime Kuma UI)
MONITOR_API_ENDPOINT=http://nginx/api/
MONITOR_CLIENT_ENDPOINT=http://nginx/
MONITOR_INTERVAL_SECONDS=60

# ============ Logging & Monitoring ============
LOG_FORMAT=json
LOG_LEVEL=INFO
SENTRY_DSN=

# ============ Performance & Resource Limits ============
API_MAX_CONNECTIONS=4096
API_REQUEST_TIMEOUT=30
NGINX_CACHE_ENABLED=true
NGINX_GZIP_ENABLED=true

# ============ CORS & Security ============
ALLOWED_ORIGINS=*
ALLOW_CREDENTIALS=true

# ============ Docker Limits ============
API_CPU_LIMIT=1
API_MEMORY_LIMIT=512M
CLIENT_CPU_LIMIT=0.5
CLIENT_MEMORY_LIMIT=256M
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=128M
